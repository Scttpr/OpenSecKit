{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://localhost"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "example\\.com"
    },
    {
      "pattern": "example\\.gouv\\.fr"
    },
    {
      "pattern": "CVE-XXXX-XXXXX"
    },
    {
      "pattern": "acme\\.com"
    },
    {
      "pattern": "\\[À COMPLÉTER\\]"
    },
    {
      "pattern": "\\[MANUEL\\]"
    },
    {
      "pattern": "\\[AUTO:"
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 202, 206, 301, 302, 999]
}
