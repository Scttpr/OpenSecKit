# OpenSecKit V4 - Compliance Assessment Template
# Generated by: /osk-comply <framework>
# Output: .osk/compliance/assessment-{{framework}}.yaml

metadata:
  schema_version: "4.0.0"
  framework: "{{framework}}"
  assessment_date: "{{timestamp}}"
  assessor: "{{assessor}}"
  system_model_version: "{{system_model_version}}"

summary:
  overall_score: {{summary.overall_score}}
  compliant_controls: {{summary.compliant_controls}}
  partial_controls: {{summary.partial_controls}}
  non_compliant_controls: {{summary.non_compliant_controls}}
  not_applicable: {{summary.not_applicable}}
  total_controls: {{summary.total_controls}}
  risk_level: "{{summary.risk_level}}"

framework_info:
  name: "{{framework_info.name}}"
  version: "{{framework_info.version}}"
  description: "{{framework_info.description}}"
  authority: "{{framework_info.authority}}"

scope:
  in_scope:
{{#each scope.in_scope}}
    - "{{this}}"
{{/each}}
  out_of_scope:
{{#each scope.out_of_scope}}
    - "{{this}}"
{{/each}}
  scope_rationale: "{{scope.scope_rationale}}"

control_assessments:
{{#each control_assessments}}
  - control_id: "{{control_id}}"
    control_name: "{{control_name}}"
    category: "{{category}}"
    description: "{{description}}"

    status: "{{status}}"
    maturity_level: {{maturity_level}}

    evidence:
{{#each evidence}}
      - type: "{{type}}"
        description: "{{description}}"
        location: "{{location}}"
        collected_date: "{{collected_date}}"
{{/each}}

    gaps:
{{#each gaps}}
      - gap_id: "{{gap_id}}"
        description: "{{description}}"
        severity: "{{severity}}"
        business_impact: "{{business_impact}}"
{{/each}}

    findings: "{{findings}}"
    recommendations: "{{recommendations}}"

    system_model_refs:
      components: [{{#each system_model_refs.components}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
      data: [{{#each system_model_refs.data}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
{{/each}}

gaps_summary:
{{#each gaps_summary}}
  - id: "{{id}}"
    control_id: "{{control_id}}"
    description: "{{description}}"
    severity: "{{severity}}"
    remediation_effort: "{{remediation_effort}}"
    priority: {{priority}}

    remediation:
      action: "{{remediation.action}}"
      responsible: "{{remediation.responsible}}"
      target_date: "{{remediation.target_date}}"
      status: "{{remediation.status}}"
{{/each}}

action_items:
{{#each action_items}}
  - id: "{{id}}"
    title: "{{title}}"
    description: "{{description}}"
    priority: "{{priority}}"
    effort: "{{effort}}"
    owner: "{{owner}}"
    due_date: "{{due_date}}"
    status: "{{status}}"
    related_gaps: [{{#each related_gaps}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
{{/each}}

cross_framework:
  mapped_to:
{{#each cross_framework.mapped_to}}
    - framework: "{{framework}}"
      controls: [{{#each controls}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
{{/each}}
  synergies:
{{#each cross_framework.synergies}}
    - "{{this}}"
{{/each}}
